rules_version = '2';

// Firestore security rules for CalStory.
//
// Each user can only read/write their own data. The data tree is
// rooted at /users/{uid} and every sub-collection (meals, workouts,
// workout_templates, recents) inherits the same per-user boundary
// via the wildcard `{document=**}` match below.
//
// Deploy with:
//   firebase deploy --only firestore:rules
//   (or paste the rules into the Firebase Console → Firestore → Rules)
service cloud.firestore {
  match /databases/{database}/documents {

    // Anything under /users/{uid} requires an authenticated user whose
    // UID matches the document path.
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Belt-and-suspenders: deny everything else by default.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
